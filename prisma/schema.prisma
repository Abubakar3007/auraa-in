generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Join {
  id         String   @id @default(cuid())
  firstName  String
  lastName   String
  email      String   @unique
  phone      String
  measurements Measurements?
  age        String
  height     String
  gender     String
  country    String
  city       String
  experience String
  instagram  String
  about      String
  images     Image[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Measurements {
  id     String @id @default(cuid())

  bust   String
  waist  String
  hip    String
  shoes  String
  hair   String
  eyes   String

  joinId String @unique
  join   Join   @relation(fields: [joinId], references: [id])
}

model Image {
  id      String @id @default(cuid())
  url     String
  joinId  String
  join    Join   @relation(fields: [joinId], references: [id])
}